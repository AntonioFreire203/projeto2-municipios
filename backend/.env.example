# Servidor
PORT=3001
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Servir o build do front-end (modo producao) -> assets estaticos comprimidos
SERVE_FRONTEND=false

# HTTPS (gere os certificados com: npm run cert)
USE_HTTPS=false
SSL_KEY_PATH=certs/key.pem
SSL_CERT_PATH=certs/cert.pem

# PostgreSQL (pool de conexoes)
DB_HOST=localhost
DB_PORT=5432
DB_USER=municipios
DB_PASSWORD=municipios
DB_NAME=municipios
DB_POOL_MAX=10

# Redis (cache + blacklist de tokens)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=troque-este-segredo-por-um-valor-aleatorio-e-longo
JWT_EXPIRES_IN=1h
